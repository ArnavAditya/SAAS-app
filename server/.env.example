# Neon Postgres connection string (Project -> Connection Details in Neon dashboard)
DATABASE_URL=

# Clerk (Dashboard -> API Keys) - secret key only, never expose this one client-side
CLERK_SECRET_KEY=

# Google AI Studio API key (for Gemini, used via the OpenAI-compatible endpoint)
GEMINI_API_KEY=

# ClipDrop API key (clipdrop.co -> API dashboard) - used for text-to-image generation
CLIPDROP_API_KEY=

# Cloudinary (Dashboard -> Account Details)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# The deployed client URL, used to restrict CORS. Comma-separate multiple origins.
# Leave unset locally to allow all origins during development.
CLIENT_URL=

# Optional - Vercel/most hosts set this automatically
PORT=3000
